generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Character {
  id          String   @id @default(cuid())
  name        String
  description String?
  personality String?
  scenario    String?
  messages    Message[]
}

model Message {
  id          String   @id @default(cuid())
  content     String
  role        String
  character   Character @relation(fields: [characterId], references: [id])
  characterId String
  createdAt   DateTime @default(now())
}